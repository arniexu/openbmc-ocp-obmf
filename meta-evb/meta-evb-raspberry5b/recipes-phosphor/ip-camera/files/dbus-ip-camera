def configure_logging() -> None:
    level_name = os.getenv("DBUS_IP_CAMERA_LOG_LEVEL", "INFO").upper()
    level = getattr(logging, level_name, logging.INFO)
    logging.basicConfig(level=level, format="%(asctime)s %(levelname)s %(message)s")


def sanitize_fragment(value: str, fallback: str) -> str:
    cleaned = re.sub(r"[^a-z0-9]+", "_", value.lower()).strip("_")
    return cleaned or fallback


def split_name(value: str) -> Dict[str, str]:
    parts = [part for part in value.split() if part]
    if len(parts) >= 2:
        return {"manufacturer": parts[0], "model": " ".join(parts[1:])}
    if parts:
        return {"manufacturer": "", "model": parts[0]}
    return {"manufacturer": "", "model": ""}


def now_usec() -> int:
    return time.time_ns() // 1000


def load_json(path: Path, default):
    try:
        with path.open("r", encoding="utf-8") as handle:
            return json.load(handle)
    except FileNotFoundError:
        return default
    except json.JSONDecodeError as error:
        LOG.warning("Failed to parse %s: %s", path, error)
        return default


def atomic_write_json(path: Path, payload) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with NamedTemporaryFile("w", encoding="utf-8", dir=path.parent, delete=False) as handle:
        json.dump(payload, handle, indent=2, sort_keys=True)
        handle.write("\n")
        temp_path = Path(handle.name)
    temp_path.replace(path)


def strip_credentials(url: str) -> str:
    parsed = urlparse(url)
    host = parsed.hostname or ""
    if ":" in host and not host.startswith("["):
        host = f"[{host}]"
    netloc = host
    if parsed.port is not None:
        netloc = f"{netloc}:{parsed.port}"
    return urlunparse((parsed.scheme, netloc, parsed.path, parsed.params, parsed.query, parsed.fragment))


def build_url(parsed, username: Optional[str], password: Optional[str]) -> str:
    host = parsed.hostname or ""
    if ":" in host and not host.startswith("["):
        host = f"[{host}]"

    netloc = host
    if parsed.port is not None:
        netloc = f"{netloc}:{parsed.port}"

    if username is not None:
        userinfo = quote(username, safe="")
        userinfo += ":" + quote(password or "", safe="")
        netloc = f"{userinfo}@{netloc}"

    return urlunparse((parsed.scheme, netloc, parsed.path, parsed.params, parsed.query, parsed.fragment))


def ensure_onvif_url(address: str) -> str:
    parsed = urlparse(address)
    if parsed.scheme:
        return address
    host = address.strip()
    if not host:
        raise ValueError("address is required")
    return f"onvif://{host}/onvif/device_service"


def extract_address(url: str) -> str:
    parsed = urlparse(url)
    return parsed.hostname or url


def make_stream_name(stream_prefix: str, source_url: str, index: int) -> str:
    parsed = urlparse(source_url)
    query = parse_qs(parsed.query)
    host = sanitize_fragment(parsed.hostname or "camera", "camera")
    token = query.get("subtype", [str(index)])[0]
    token = sanitize_fragment(token, str(index))
    prefix = sanitize_fragment(stream_prefix, "ipcam")
    return f"{prefix}_{host}_{token}"


