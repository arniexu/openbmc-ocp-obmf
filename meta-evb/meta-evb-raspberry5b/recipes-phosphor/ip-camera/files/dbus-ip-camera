class CameraService:
    def __init__(self, bus, config: Dict[str, object]):
        self.bus = bus
        self.config = config
        self.state_path = Path(str(config.get("state_path", "/var/lib/dbus-ip-camera/state.json")))
        self.inventory_root = str(config.get("inventory_root", "/xyz/openbmc_project/inventory/system/chassis/camera")).rstrip("/")
        self.auto_add_discovered = bool(config.get("auto_add_discovered", True))
        self.auto_import_streams = bool(config.get("auto_import_streams", True))
        self.discovery_interval_sec = int(config.get("discovery_interval_sec", 300))
        self.poll_interval_sec = int(config.get("poll_interval_sec", 60))
        self.stream_prefix = str(config.get("stream_prefix", "ipcam"))
        self._lock = asyncio.Lock()
        self._periodic_task = None
        state = load_json(self.state_path, {"cameras": {}})
        self.state = {"cameras": state.get("cameras", {})}
        self.manager = ManagerInterface(self)
        self.camera_objects: Dict[str, CameraObject] = {}

    async def start(self) -> None:
        self.bus.export(MANAGER_PATH, self.manager)
        for slug in list(self.state["cameras"].keys()):
            self._export_camera(slug)
            self._sync_camera_interfaces(slug)
        self._sync_manager()
        await self.discover_and_refresh()
        self._periodic_task = asyncio.create_task(self._periodic_refresh_loop())

    async def _periodic_refresh_loop(self) -> None:
        while True:
            try:
                await self.discover_and_refresh()
                await asyncio.sleep(self.discovery_interval_sec)
            except asyncio.CancelledError:
                raise
            except Exception as error:  # noqa: BLE001
                LOG.exception("Periodic refresh failed: %s", error)
                await asyncio.sleep(self.poll_interval_sec)

    def api_base(self) -> str:
        return str(self.config.get("go2rtc_api", "http://127.0.0.1:1984")).rstrip("/")

    async def request_json(self, path: str, query=None, method: str = "GET"):
        return await asyncio.to_thread(self._request_json_sync, path, query, method)

    def _request_json_sync(self, path: str, query=None, method: str = "GET"):
        url = self.api_base() + "/" + path.lstrip("/")
        if query:
            url += "?" + urlencode(query, doseq=True)
        request = Request(url, method=method)
        with urlopen(request, timeout=10) as response:
            return json.load(response)

    async def request_sources(self, path: str, query=None):
        try:
            payload = await self.request_json(path, query=query)
        except HTTPError as error:
            if error.code == 404:
                return []
            raise

        if isinstance(payload, dict):
            return payload.get("sources", [])
        return []

    def camera_paths(self) -> List[str]:
        return [self.camera_path(slug) for slug in sorted(self.state["cameras"].keys())]

    def camera_path(self, slug: str) -> str:
        return f"{self.inventory_root}/{slug}"

    def stream_path(self, slug: str, stream_slug: str) -> str:
        return f"{self.camera_path(slug)}/stream/{stream_slug}"

    def _sync_manager(self) -> None:
        self.manager.update(self.camera_paths(), self.auto_add_discovered, self.poll_interval_sec)

    def _save_state(self) -> None:
        atomic_write_json(self.state_path, self.state)

    def _export_camera(self, slug: str) -> None:
        if slug in self.camera_objects:
            return
        path = self.camera_path(slug)
        obj = CameraObject(self, slug, path)
        self.camera_objects[slug] = obj
        self.bus.export(path, obj.inventory)
        self.bus.export(path, obj.operational)
        self.bus.export(path, obj.asset)
        self.bus.export(path, obj.device)

    def _unexport_camera(self, slug: str) -> None:
        obj = self.camera_objects.pop(slug, None)
        if not obj:
            return
        for stream_slug in list(obj.streams.keys()):
            self.bus.unexport(self.stream_path(slug, stream_slug), obj.streams[stream_slug]["interface"])
        self.bus.unexport(obj.path, obj.inventory)
        self.bus.unexport(obj.path, obj.operational)
        self.bus.unexport(obj.path, obj.asset)
        self.bus.unexport(obj.path, obj.device)

    def _sync_camera_interfaces(self, slug: str) -> None:
        camera = self.state["cameras"][slug]
        self._export_camera(slug)
        obj = self.camera_objects[slug]

        name = str(camera.get("name") or extract_address(str(camera.get("endpoint", ""))))
        asset_parts = split_name(name)
        manufacturer = str(camera.get("manufacturer") or asset_parts["manufacturer"])
        model = str(camera.get("model") or asset_parts["model"])
        obj.inventory.update(bool(camera.get("present", False)))
        obj.operational.update(bool(camera.get("functional", False)))
        obj.asset.update(
            manufacturer,
            model,
            str(camera.get("hardware_id", "")),
            str(camera.get("serial_number", "")),
            str(camera.get("build_date", "")),
        )

        streams = camera.get("streams", {})
        profile_paths = []
        existing = set(obj.streams.keys())
        desired = set(streams.keys())
        for removed in existing - desired:
            stream_state = obj.streams.pop(removed)
            self.bus.unexport(self.stream_path(slug, removed), stream_state["interface"])
        for stream_slug in sorted(desired):
            path = self.stream_path(slug, stream_slug)
            profile_paths.append(path)
            if stream_slug not in obj.streams:
                interface = StreamInterface(self, slug, stream_slug)
                self.bus.export(path, interface)
                obj.streams[stream_slug] = {"interface": interface}
            obj.streams[stream_slug]["interface"].update(streams[stream_slug])

        obj.device.update(camera, profile_paths)
        self._sync_manager()

    def _camera_credentials(self, camera: Dict[str, object]) -> List[tuple]:
        credentials = []
        username = str(camera.get("username", ""))
        password = str(camera.get("password", ""))
        if username or password:
            credentials.append((username, password))
        credentials.append((None, None))
        return credentials

    async def discover_and_refresh(self) -> None:
        async with self._lock:
            try:
                discovered = await self.request_sources("api/onvif")
            except (HTTPError, URLError) as error:
                LOG.warning("Discovery failed: %s", error)
                discovered = []

            for item in discovered:
                endpoint = strip_credentials(str(item.get("url", "")))
                if not endpoint:
                    continue
                address = extract_address(endpoint)
                slug = sanitize_fragment(address, "camera")
                if slug not in self.state["cameras"] and not self.auto_add_discovered:
                    continue
                camera = self.state["cameras"].setdefault(slug, {"managed": True, "streams": {}})
                camera["address"] = address
                camera["endpoint"] = endpoint
                camera["name"] = item.get("name", address)
                camera["raw_info"] = item.get("info", "")
                camera["location"] = item.get("location", "")
                self._export_camera(slug)

            for slug in list(self.state["cameras"].keys()):
                await self._refresh_camera_locked(slug, self.auto_import_streams)

            self._save_state()
            for slug in list(self.state["cameras"].keys()):
                self._sync_camera_interfaces(slug)

    async def refresh_all(self) -> None:
        async with self._lock:
            for slug in list(self.state["cameras"].keys()):
                await self._refresh_camera_locked(slug, self.auto_import_streams)
            self._save_state()
            for slug in list(self.state["cameras"].keys()):
                self._sync_camera_interfaces(slug)

    async def refresh_one(self, slug: str, import_streams: bool) -> None:
        async with self._lock:
            await self._refresh_camera_locked(slug, import_streams)
            self._save_state()
            self._sync_camera_interfaces(slug)

    async def _refresh_camera_locked(self, slug: str, import_streams: bool) -> None:
        camera = self.state["cameras"].get(slug)
        if not camera:
            raise ValueError(f"unknown camera {slug}")

        endpoint = ensure_onvif_url(str(camera.get("endpoint") or camera.get("address") or ""))
        camera["endpoint"] = strip_credentials(endpoint)
        camera["address"] = extract_address(endpoint)
        camera["last_refresh_usec"] = now_usec()

        selected_url = None
        profile_items = []
        last_error = ""
        for username, password in self._camera_credentials(camera):
            candidate = build_url(urlparse(endpoint), username, password)
            try:
                profile_items = await self.request_sources("api/onvif", {"src": candidate})
            except (HTTPError, URLError) as error:
                last_error = str(error)
                continue
            if profile_items:
                selected_url = candidate
                break

        if selected_url is None:
            camera["present"] = False
            camera["functional"] = False
            camera["auth_status"] = "failed"
            camera["last_error"] = last_error or "unable to enumerate profiles"
            return

        previous_streams = {
            str(entry.get("stream_name", "")): str(entry.get("stream_url", ""))
            for entry in camera.get("streams", {}).values()
            if entry.get("stream_name")
        }

        new_streams = {}
        snapshot_support = False
        for index, profile in enumerate(profile_items):
            profile_url = str(profile.get("url", ""))
            if not profile_url:
                continue
            snapshot = "snapshot" in parse_qs(urlparse(profile_url).query)
            snapshot_support = snapshot_support or snapshot
            if snapshot:
                continue
            stream_name = make_stream_name(self.stream_prefix, profile_url, index)
            stream_slug = sanitize_fragment(stream_name, f"stream_{index}")
            profile_token = parse_qs(urlparse(profile_url).query).get("subtype", [str(index)])[0]
            new_streams[stream_slug] = {
                "profile_name": str(profile.get("name", "")),
                "profile_token": profile_token,
                "snapshot": False,
                "stream_name": stream_name,
                "stream_url": profile_url,
            }

        camera["streams"] = new_streams
        camera["present"] = True
        camera["functional"] = True
        camera["auth_status"] = "ok"
        camera["snapshot_support"] = snapshot_support
        camera["last_seen_usec"] = now_usec()
        camera["last_error"] = ""

        if import_streams:
            await self._reconcile_go2rtc_streams(previous_streams, new_streams)

    async def _reconcile_go2rtc_streams(self, previous_streams: Dict[str, str], new_streams: Dict[str, Dict[str, object]]) -> None:
        desired = {str(entry["stream_name"]): str(entry["stream_url"]) for entry in new_streams.values()}
        for stale_name in sorted(set(previous_streams.keys()) - set(desired.keys())):
            try:
                await self.request_json("api/streams", {"src": stale_name}, method="DELETE")
            except (HTTPError, URLError) as error:
                LOG.warning("Failed deleting stale stream %s: %s", stale_name, error)
        for name, source_url in desired.items():
            try:
                await self.request_json("api/streams", {"name": name, "src": source_url}, method="PUT")
            except (HTTPError, URLError) as error:
                LOG.warning("Failed importing stream %s: %s", name, error)

    async def import_streams(self, slug: str) -> None:
        async with self._lock:
            camera = self.state["cameras"][slug]
            await self._reconcile_go2rtc_streams({}, camera.get("streams", {}))

    async def delete_streams(self, slug: str) -> None:
        async with self._lock:
            camera = self.state["cameras"][slug]
            for stream in camera.get("streams", {}).values():
                name = stream.get("stream_name")
                if not name:
                    continue
                try:
                    await self.request_json("api/streams", {"src": name}, method="DELETE")
                except (HTTPError, URLError) as error:
                    LOG.warning("Failed deleting stream %s: %s", name, error)

    async def import_camera_stream(self, camera_slug: str, stream_slug: str) -> None:
        async with self._lock:
            stream = self.state["cameras"][camera_slug].get("streams", {}).get(stream_slug)
            if not stream:
                raise ValueError("unknown stream")
            await self.request_json("api/streams", {"name": stream["stream_name"], "src": stream["stream_url"]}, method="PUT")

    async def remove_camera_stream(self, camera_slug: str, stream_slug: str) -> None:
        async with self._lock:
            stream = self.state["cameras"][camera_slug].get("streams", {}).get(stream_slug)
            if not stream:
                raise ValueError("unknown stream")
            await self.request_json("api/streams", {"src": stream["stream_name"]}, method="DELETE")

    async def set_camera_credentials(self, slug: str, username: str, password: str) -> None:
        async with self._lock:
            camera = self.state["cameras"][slug]
            camera["username"] = username
            camera["password"] = password
            await self._refresh_camera_locked(slug, self.auto_import_streams)
            self._save_state()
            self._sync_camera_interfaces(slug)

    async def add_camera(self, address: str, username: str, password: str, import_streams: bool) -> str:
        async with self._lock:
            endpoint = ensure_onvif_url(address)
            slug = sanitize_fragment(extract_address(endpoint), "camera")
            camera = self.state["cameras"].setdefault(slug, {"managed": True, "streams": {}})
            camera["address"] = extract_address(endpoint)
            camera["endpoint"] = strip_credentials(endpoint)
            camera["username"] = username
            camera["password"] = password
            camera["managed"] = True
            if not camera.get("name"):
                camera["name"] = camera["address"]
            self._export_camera(slug)
            await self._refresh_camera_locked(slug, import_streams)
            self._save_state()
            self._sync_camera_interfaces(slug)
            return self.camera_path(slug)

    async def remove_camera_by_path(self, path: str) -> None:
        async with self._lock:
            slug = None
            for candidate in self.state["cameras"].keys():
                if self.camera_path(candidate) == path:
                    slug = candidate
                    break
            if slug is None:
                raise ValueError(f"unknown camera path {path}")
            camera = self.state["cameras"][slug]
            for stream in camera.get("streams", {}).values():
                name = stream.get("stream_name")
                if not name:
                    continue
                try:
                    await self.request_json("api/streams", {"src": name}, method="DELETE")
                except (HTTPError, URLError) as error:
                    LOG.warning("Failed deleting stream %s: %s", name, error)
            self.state["cameras"].pop(slug, None)
            self._unexport_camera(slug)
            self._save_state()
            self._sync_manager()


async def main() -> int:
    configure_logging()

    config = load_json(Path(DEFAULT_CONFIG_PATH), {})
    bus = await MessageBus(bus_type=BusType.SYSTEM).connect()
    await bus.request_name(SERVICE_NAME)

    camera_service = CameraService(bus, config)
    await camera_service.start()

    stop_event = asyncio.Event()
    try:
        loop = asyncio.get_running_loop()
        loop.add_signal_handler(signal.SIGINT, stop_event.set)
        loop.add_signal_handler(signal.SIGTERM, stop_event.set)
    except (NotImplementedError, RuntimeError, ValueError):
        pass

    await stop_event.wait()
    return 0


if __name__ == "__main__":
    try:
        sys.exit(asyncio.run(main()))
    except KeyboardInterrupt:
        sys.exit(0)